@page "/responses-demo"
@using System.Text
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

@* ─── Header ─── *@
<header class="site-header">
    <h1>📡 Responses API — SSE Inspector</h1>
    <div class="header-links">
        <a href="/">🎲 Gioco</a>
        <a href="/devui" target="_blank">🛠️ DevUI</a>
    </div>
</header>

@* ─── Info Bar: endpoint + previous_response_id chain ─── *@
<div class="resp-infobar">
    <div class="resp-infobar-left">
        <code class="resp-endpoint">POST /v1/responses</code>
        <span class="resp-sep">·</span>
        <span class="resp-chain-label">response chain:</span>
        @if (_responseChain.Count == 0)
        {
            <span class="resp-chain-empty">nessuna sessione attiva</span>
        }
        else
        {
            @for (var i = 0; i < _responseChain.Count; i++)
            {
                var id = _responseChain[i];
                var isCurrent = i == _responseChain.Count - 1;
                <span class="resp-chain-id @(isCurrent ? "current" : "")">@id[..16]…</span>
                @if (i < _responseChain.Count - 1)
                {
                    <span class="resp-chain-arrow">→</span>
                }
            }
        }
    </div>
    <button class="resp-reset-btn" @onclick="ResetSession" title="Azzera la sessione: il prossimo messaggio non userà previous_response_id">
        🔄 Nuova Sessione
    </button>
</div>

@* ─── Main: chat + event stream ─── *@
<div class="resp-main">

    @* Left: Conversazione pulita *@
    <div class="resp-chat-panel">
        <div class="resp-panel-title">💬 Conversazione</div>
        <div class="resp-chat-messages" id="chatArea">
            @foreach (var msg in _chatMessages)
            {
                <div class="resp-chat-msg @msg.Role">
                    @if (msg.Role == "assistant")
                    {
                        <span class="resp-chat-badge">🤖</span>
                    }
                    else if (msg.Role == "user")
                    {
                        <span class="resp-chat-badge">🧑</span>
                    }
                    @((MarkupString)msg.HtmlText)
                </div>
            }
            @if (_isStreaming && _streamingText.Length > 0)
            {
                <div class="resp-chat-msg assistant streaming">
                    <span class="resp-chat-badge">🤖</span>
                    @_streamingText<span class="resp-cursor">▋</span>
                </div>
            }
            @if (_isStreaming && _streamingText.Length == 0)
            {
                <div class="resp-chat-msg assistant">
                    <span class="resp-chat-badge">🤖</span>
                    <span class="resp-thinking">elaborazione in corso…</span>
                </div>
            }
        </div>
    </div>

    @* Right: SSE Event Stream *@
    <div class="resp-events-panel">
        <div class="resp-panel-title">
            📡 SSE Event Stream
            <span class="resp-events-count">@_events.Count eventi</span>
        </div>
        <div class="resp-events-list" id="eventsArea">
            @if (_events.Count == 0)
            {
                <div class="resp-events-placeholder">
                    Gli eventi SSE appariranno qui in tempo reale.<br/>
                    Ogni <code>data: {…}</code> del protocollo è un evento.
                </div>
            }
            @foreach (var ev in _events)
            {
                <div class="resp-evt @ev.CssClass">
                    <span class="resp-evt-type">@ev.EventType</span>
                    @if (!string.IsNullOrEmpty(ev.Detail))
                    {
                        <span class="resp-evt-detail">@ev.Detail</span>
                    }
                </div>
            }
        </div>
    </div>

</div>

@* ─── Bottom: controlli input ─── *@
<div class="resp-bottom-bar">
    <select class="resp-model-select" @bind="_selectedModel" disabled="@_isStreaming">
        <option value="game-master">🎩 game-master</option>
        <option value="goose-game">🎲 goose-game (workflow)</option>
        <option value="challenge-agent">🎯 challenge-agent</option>
        <option value="prison-agent">🔒 prison-agent</option>
        <option value="score-agent">📊 score-agent</option>
    </select>
    <input class="resp-input" type="text" @bind="_userInput" @bind:event="oninput"
           placeholder="Scrivi un messaggio e guarda gli eventi SSE arrivare..."
           disabled="@_isStreaming"
           @onkeydown="OnKeyDown" />
    <button class="resp-send-btn" @onclick="SendRequest" disabled="@_isStreaming">
        @(_isStreaming ? "⏳" : "🚀") Invia
    </button>
</div>

@code {
    // ─── State ───────────────────────────────────────────────────────────────
    private string _selectedModel = "game-master";
    private string _userInput    = "";
    private bool   _isStreaming;
    private string _streamingText = "";

    // previous_response_id: il SERVER mantiene la cronologia,
    // il client manda solo l'ultimo messaggio
    private string?      _currentResponseId;
    private readonly List<string>      _responseChain = [];
    private readonly List<ChatMsg>     _chatMessages  = [];
    private readonly List<SseEvent>    _events        = [];

    // ─── Records ─────────────────────────────────────────────────────────────
    private record ChatMsg(string Role, string RawText)
    {
        public string HtmlText =>
            System.Net.WebUtility.HtmlEncode(RawText).Replace("\n", "<br/>");
    }

    private record SseEvent(string EventType, string Detail, string CssClass);

    // ─── Lifecycle ───────────────────────────────────────────────────────────
    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_isStreaming)
            _ = SendRequest();
    }

    private void ResetSession()
    {
        _currentResponseId = null;
        _responseChain.Clear();
        _chatMessages.Clear();
        _events.Clear();
        _streamingText = "";
    }

    // ─── Request ─────────────────────────────────────────────────────────────
    private async Task SendRequest()
    {
        var input = _userInput?.Trim();
        if (string.IsNullOrEmpty(input) || _isStreaming) return;

        _userInput      = "";
        _isStreaming    = true;
        _streamingText  = "";
        _events.Clear();
        _chatMessages.Add(new("user", input));
        StateHasChanged();

        // ── Corpo della request ──────────────────────────────────────────────
        // previous_response_id è il cuore delle Responses API:
        // il server ricostruisce tutta la conversazione da solo,
        // il client manda solo l'ultimo turno.
        var body = new Dictionary<string, object?>
        {
            ["model"]  = _selectedModel,
            ["agent"]  = new Dictionary<string, string> { ["name"] = _selectedModel, ["type"] = "agent_reference" },
            ["input"]  = input,
            ["stream"] = true,
        };
        if (_currentResponseId is not null)
            body["previous_response_id"] = _currentResponseId;

        AddEvent("→ REQUEST",
            $"model={_selectedModel}" +
            (_currentResponseId is not null
                ? $"  previous_response_id={_currentResponseId[..16]}…"
                : "  (nuova sessione, nessun previous_response_id)"),
            "resp-evt-req");

        try
        {
            using var client  = CreateClient();
            using var request = new HttpRequestMessage(HttpMethod.Post, "/v1/responses")
            {
                Content = JsonContent.Create(body)
            };

            using var response = await client.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);

            if (!response.IsSuccessStatusCode)
            {
                var err = await response.Content.ReadAsStringAsync();
                AddEvent("error", err[..Math.Min(120, err.Length)], "resp-evt-error");
                _chatMessages.Add(new("error", $"Errore HTTP {(int)response.StatusCode}"));
                return;
            }

            var fullText = new StringBuilder();
            using var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new StreamReader(stream);

            while (await reader.ReadLineAsync() is { } line)
            {
                if (!line.StartsWith("data: ")) continue;

                var payload = line[6..].Trim();

                if (payload == "[DONE]")
                {
                    AddEvent("[DONE]", "stream completato", "resp-evt-done");
                    break;
                }

                try   { ProcessSseEvent(payload, fullText); }
                catch { /* skip malformed events */ }

                await Task.Delay(8);
                await InvokeAsync(StateHasChanged);
                await JS.InvokeVoidAsync("scrollToBottom", "eventsArea");
            }

            // Committing the final text to chat
            var finalText = fullText.ToString();
            if (!string.IsNullOrEmpty(finalText))
                _chatMessages.Add(new("assistant", finalText));
            else
                _chatMessages.Add(new("assistant", "(risposta senza testo di output)"));
        }
        catch (Exception ex)
        {
            AddEvent("exception", ex.Message, "resp-evt-error");
        }
        finally
        {
            _isStreaming   = false;
            _streamingText = "";
            StateHasChanged();
            await JS.InvokeVoidAsync("scrollToBottom", "chatArea");
        }
    }

    // ─── SSE Event Parser ────────────────────────────────────────────────────
    private void ProcessSseEvent(string json, StringBuilder fullText)
    {
        var evt = JsonSerializer.Deserialize<JsonElement>(json);
        if (!evt.TryGetProperty("type", out var typeProp)) return;
        var type = typeProp.GetString() ?? "unknown";

        switch (type)
        {
            // ── Lifecycle ──────────────────────────────────────────────────
            case "response.created":
                if (evt.TryGetProperty("response", out var r) &&
                    r.TryGetProperty("id", out var rid))
                {
                    _currentResponseId = rid.GetString();
                    if (_currentResponseId is not null)
                        _responseChain.Add(_currentResponseId);
                }
                AddEvent(type, $"id={_currentResponseId?[..16]}…", "resp-evt-meta");
                break;

            case "response.in_progress":
                AddEvent(type, "", "resp-evt-meta");
                break;

            // ── Output item aperto ─────────────────────────────────────────
            case "response.output_item.added":
                var iType = "";
                if (evt.TryGetProperty("item", out var item))
                {
                    item.TryGetProperty("type", out var itp);
                    iType = itp.GetString() ?? "";
                    // Se è una function call, mostra il nome
                    if (iType == "function_call" && item.TryGetProperty("name", out var fn))
                        iType += $"  name={fn.GetString()}";
                }
                AddEvent(type, $"item.type={iType}", "resp-evt-meta");
                break;

            case "response.content_part.added":
                AddEvent(type, "", "resp-evt-meta");
                break;

            // ── Text streaming ─────────────────────────────────────────────
            case "response.output_text.delta":
                if (evt.TryGetProperty("delta", out var delta))
                {
                    var chunk = delta.GetString() ?? "";
                    fullText.Append(chunk);
                    _streamingText = fullText.ToString();
                    // Mostra solo delta con contenuto (evita spam di singoli caratteri)
                    if (chunk.Length > 2 || chunk is "\n" or " ")
                        AddEvent(type, $"\"{Truncate(chunk, 45)}\"", "resp-evt-text");
                }
                break;

            case "response.output_text.done":
                var totalChars = evt.TryGetProperty("text", out var doneText)
                    ? doneText.GetString()?.Length ?? 0 : 0;
                AddEvent(type, $"{totalChars} caratteri totali", "resp-evt-text-done");
                break;

            // ── Tool call (function call) streaming ────────────────────────
            case "response.function_call_arguments.delta":
                if (evt.TryGetProperty("delta", out var argDelta))
                    AddEvent(type, Truncate(argDelta.GetString() ?? "", 55), "resp-evt-tool");
                break;

            case "response.function_call_arguments.done":
                var args = evt.TryGetProperty("arguments", out var a) ? a.GetString() ?? "" : "";
                AddEvent(type, Truncate(args, 80), "resp-evt-tool-done");
                break;

            // ── Output item chiuso ─────────────────────────────────────────
            case "response.output_item.done":
                AddEvent(type, "", "resp-evt-meta");
                break;

            case "response.content_part.done":
                AddEvent(type, "", "resp-evt-meta");
                break;

            // ── Completamento ──────────────────────────────────────────────
            case "response.completed":
                var usageInfo = "";
                if (evt.TryGetProperty("response", out var completedResp) &&
                    completedResp.TryGetProperty("usage", out var usage))
                {
                    var inp = usage.TryGetProperty("input_tokens",  out var it) ? it.GetInt32() : 0;
                    var out_ = usage.TryGetProperty("output_tokens", out var ot) ? ot.GetInt32() : 0;
                    usageInfo = $"input_tokens={inp}  output_tokens={out_}";
                }
                AddEvent(type, usageInfo, "resp-evt-completed");
                break;

            default:
                AddEvent(type, "", "resp-evt-meta");
                break;
        }
    }

    // ─── Helpers ─────────────────────────────────────────────────────────────
    private void AddEvent(string type, string detail, string css)
        => _events.Add(new(type, detail, css));

    private static string Truncate(string s, int max)
        => s.Length <= max ? s : s[..max] + "…";

    private HttpClient CreateClient()
    {
        var c = HttpClientFactory.CreateClient();
        c.BaseAddress = new Uri(Nav.BaseUri);
        return c;
    }

    public void Dispose() { }
}
